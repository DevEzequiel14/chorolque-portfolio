---
import { projects } from "../../data/projects";
const totalProjects = projects.length;
---

<div class="projects-card" data-total={totalProjects}>
  {
    projects.map((_, index) => (
      <input
        class="projects-card__input"
        type="radio"
        name="project"
        id={`project_${index + 1}`}
        checked={index === 0}
      />
    ))
  }

  <div class="projects-card__content">
    <h1 class="projects-card__title">Proyectos</h1>
    <div
      class="projects-card__image-container"
      role="region"
      aria-label="Proyectos destacados"
    >
      {
        projects.map((project, index) => (
          <a
            href={`/work/${project.slug}`}
            class="projects-card__link"
            data-index={index + 1}
            aria-label={`Ver detalle del proyecto ${project.title}`}
          >
            <img
              class="projects-card__image"
              src={project.image}
              data-index={index + 1}
              alt={`Vista previa del proyecto ${project.title}`}
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={index === 0 ? "high" : "low"}
            />
            <div class="projects-card__overlay">
              <div class="projects-card__overlay-content">
                <span class="projects-card__project-title">
                  {project.title}
                </span>
                <svg
                  class="projects-card__icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <div
    class="projects-card__slider"
    role="tablist"
    aria-label="Selector de proyectos"
  >
    {
      projects.map((project, index) => (
        <label
          class="projects-card__dot"
          for={`project_${index + 1}`}
          data-index={index + 1}
          role="tab"
          tabindex="0"
          aria-selected={index === 0 ? "true" : "false"}
          aria-label={`Mostrar proyecto ${project.title}`}
        />
      ))
    }
  </div>
</div>

<script is:inline>
  const card = document.querySelector(".projects-card");

  if (card && card.dataset.initialized !== "true") {
    card.dataset.initialized = "true";

    let current = 1;
    const inputs = card.querySelectorAll(".projects-card__input");
    const links = card.querySelectorAll(".projects-card__link");
    const dots = card.querySelectorAll(".projects-card__dot");
    const total =
      Number.parseInt(card.dataset.total || "", 10) || inputs.length;
    let intervalId;
    const controller = new AbortController();
    const { signal } = controller;

    function updateContentVisibility() {
      links.forEach((link) => {
        const index = Number(link.dataset.index);
        link.style.opacity = index === current ? "1" : "0";
        link.style.pointerEvents = index === current ? "auto" : "none";
        link.style.zIndex = index === current ? "2" : "1";
        link.setAttribute("aria-hidden", index === current ? "false" : "true");
      });

      dots.forEach((dot) => {
        dot.classList.toggle(
          "is-active",
          Number(dot.dataset.index) === current,
        );
        dot.setAttribute(
          "aria-selected",
          Number(dot.dataset.index) === current ? "true" : "false",
        );
      });
    }

    function goToNextSlide() {
      if (total <= 0) return;
      current = (current % total) + 1;
      const nextInput = card.querySelector(`#project_${current}`);
      if (nextInput) nextInput.checked = true;
      updateContentVisibility();
    }

    function startAutoSlide() {
      clearInterval(intervalId);
      if (total > 0) {
        intervalId = setInterval(goToNextSlide, 5000);
      }
    }

    inputs.forEach((input, idx) => {
      input.addEventListener(
        "change",
        () => {
          if (input.checked) {
            current = idx + 1;
            updateContentVisibility();
            startAutoSlide();
          }
        },
        { signal },
      );
    });

    dots.forEach((dot) => {
      dot.addEventListener(
        "keydown",
        (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          const targetIndex = Number(dot.dataset.index);
          const targetInput = card.querySelector(`#project_${targetIndex}`);
          if (targetInput) {
            targetInput.checked = true;
            targetInput.dispatchEvent(new Event("change", { bubbles: true }));
          }
        },
        { signal },
      );
    });

    document.addEventListener(
      "visibilitychange",
      () => {
        if (document.hidden) {
          clearInterval(intervalId);
        } else {
          startAutoSlide();
        }
      },
      { signal },
    );

    const firstInput = card.querySelector("#project_1");
    if (firstInput) {
      firstInput.checked = true;
    }
    updateContentVisibility();
    startAutoSlide();

    window.addEventListener(
      "pagehide",
      () => {
        clearInterval(intervalId);
        controller.abort();
        delete card.dataset.initialized;
      },
      { once: true },
    );
  }
</script>
